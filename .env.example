# ──────────────────────────────────────────────────────────
#  Variables de entorno del frontend (Vite)
#  Copia este archivo como .env.local y edita los valores.
#    Windows:  copy .env.example .env.local
#    Mac/Linux: cp .env.example .env.local
# ──────────────────────────────────────────────────────────

# URL del backend — cambia TU_IP_O_HOST según tu caso:
#   localhost           → backend en tu misma máquina
#   192.168.1.X         → backend en otra PC de la red
#   servidor.ejemplo.com → backend en un servidor remoto

VITE_API_URL_TOP=http://TU_IP_O_HOST:3000/api/datos?collection=processed_readings
VITE_API_URL_TODOS=http://TU_IP_O_HOST:3000/api/datos?collection=processed_readings
